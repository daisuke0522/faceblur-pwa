{
  "buildCommand": "mkdir -p dist/assets && cp index.html face-blur-app.html manifest.json service-worker.js privacy.html dist/ && cp apple-touch-icon.png icon-192.png icon-512.png dist/assets/",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "headers": [
    {
      "source": "/manifest.json",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/manifest+json; charset=utf-8"
        }
      ]
    },
    {
      "source": "/service-worker.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache"
        }
      ]
    }
  ]
}
